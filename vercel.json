{
    "version": 2,
    "framework": null,
    "buildCommand": "npm run build",
    "functions": {
        "api/index.php": { "runtime": "vercel-php@0.7.3" }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/build/$1"
        },
        {
            "src": "/images/(.*)",
            "dest": "/images/$1"
        },
        {
            "src": "/storage/(.*)",
            "dest": "/storage/$1"
        },
        {
            "src": "/(favicon\\.ico|robots\\.txt)",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "outputDirectory": "public",
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://restaurant-ordering-green.vercel.app",
        "APP_KEY": "base64:HvbBu0n7pGT5iHUNMjaLLrC6RCd1ZFiZkdNn3DrdPHA=",

        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "VIEW_COMPILED_PATH": "/tmp",
        "LOG_EMERGENCY_PATH": "/tmp/laravel-emergency.log",

        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",

        "DB_CONNECTION": "mysql",
        "DB_HOST": "kodama.proxy.rlwy.net",
        "DB_PORT": "45112",
        "DB_DATABASE": "railway",
        "DB_USERNAME": "root",
        "DB_PASSWORD": "BtwvPEBxCtGQUXlVvgkOEjmyKKnVJDKA"
    }
}
